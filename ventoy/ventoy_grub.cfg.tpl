# Fedora + Fedora Install Profiles — custom Ventoy GRUB entries
# Auto-generated by fedora-install.sh — do not edit by hand
#
# Placeholders substituted at deploy time:
#   FEDORA_ISO_FILENAME  — e.g. Fedora-Everything-netinst-x86_64-43-1.6.iso
#   FEDORA_ISO_CDLABEL   — (nicht mehr verwendet, Fedora netinstall nutzt inst.stage2)
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Fedora Everything Netinstall ISO — Anaconda bootet direkt, liest inst.ks  │
# │  [m]  VM-Test           →  ISO-Boot → Anaconda → fedora-vm.ks              │
# │  [f]  Vollinstallation  →  ISO-Boot → Anaconda → fedora-full.ks            │
# │  [t]  Theme + Bash      ─┐                                                  │
# │  [h]  Headless vLLM     ─┤ laufen auf BESTEHENDEM System:                  │
# │  [v]  vLLM only         ─┘ fedora-provision.sh vom USB starten              │
# └─────────────────────────────────────────────────────────────────────────────┘
#
# Disk-Override: Im GRUB-Menü (e) an die linux-Zeile anhängen:
#   inst.disk=nvme1n1      (z.B. zweite NVMe)
#   inst.disk=sdb          (z.B. zweite SATA-Disk)
# Ohne Override: größte interne Disk wird automatisch gewählt.
#
# Fedora Netinstall via Ventoy:
#   inst.stage2=hd:LABEL=Ventoy:${isofile}  →  Anaconda findet stage2 im ISO
#   inst.ks=hd:LABEL=Ventoy:/kickstart/...  →  Kickstart-Datei vom USB
#   Anaconda installiert über Internet (Fedora + Fedora-Repos via %post)

# ── [m] VM-Test — Anaconda + fedora-vm.ks (KVM/virtio, 80GB vda) ─────────────
menuentry "Fedora -- [m] VM-Test           (Anaconda → fedora-vm.ks)" --hotkey=m {
    search --no-floppy --label --set=root Ventoy
    set isofile="/FEDORA_ISO_FILENAME"
    loopback loop $isofile
    linux  (loop)/images/pxeboot/vmlinuz inst.stage2=hd:LABEL=Ventoy:${isofile} inst.ks=hd:LABEL=Ventoy:/kickstart/fedora-vm.ks nomodeset quiet
    initrd (loop)/images/pxeboot/initrd.img
}

# ── [f] Vollinstallation — Anaconda + fedora-full.ks ─────────────────────────
menuentry "Fedora -- [f] Vollinstallation  (Anaconda → fedora-full.ks)" --hotkey=f {
    search --no-floppy --label --set=root Ventoy
    set isofile="/FEDORA_ISO_FILENAME"
    loopback loop $isofile
    linux  (loop)/images/pxeboot/vmlinuz inst.stage2=hd:LABEL=Ventoy:${isofile} inst.ks=hd:LABEL=Ventoy:/kickstart/fedora-full.ks nomodeset quiet
    initrd (loop)/images/pxeboot/initrd.img
}

# ── [t] Theme + Bash — Provisioner auf bestehendem System starten ────────────
menuentry "Fedora -- [t] Theme + Bash       (bestehende Installation → Provisioner)" --hotkey=t {
    echo ""
    echo "Dieses Profil installiert kein neues System."
    echo "Im laufenden System ausfuehren:"
    echo ""
    echo "  sudo bash /run/media/USER/Ventoy/fedora-provision.sh --profile theme-bash"
    echo ""
    echo "Taste druecken um fortzufahren ..."
    sleep -1
}


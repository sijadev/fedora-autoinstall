# ─────────────────────────────────────────────────────────────────────────────
# Containerfile.vllm — Custom vLLM image für NVIDIA RTX 9070 (Blackwell sm_120)
#
# Build:
#   podman build -f Containerfile.vllm -t fedora-vllm:latest \
#     --build-arg MAX_JOBS=$(nproc) .
#
# Run (via Quadlet oder manuell):
#   podman run --rm -it \
#     --device nvidia.com/gpu=all --ipc=host --shm-size=16g \
#     -p 8000:8000 \
#     -v ~/.models/huggingface:/root/.cache/huggingface:Z \
#     fedora-vllm:latest \
#     --model Qwen/Qwen3-14B-AWQ --gpu-memory-utilization 0.90
#
# Optimierungen gegenüber vllm/vllm-openai:latest:
#   - TORCH_CUDA_ARCH_LIST=12.0  → CUDA-Kernel direkt für Blackwell kompiliert
#   - NCCL_DMABUF_ENABLE=1       → schnellerer GPU-Datentransfer (Kernel 6.14+)
#   - VLLM_FLASH_ATTN_VERSION=2  → Flash Attention 3 noch inkompatibel mit Blackwell
#   - NGC Base Image              → produktionsreifes CUDA + PyTorch von NVIDIA
#   - ~10-15% mehr tokens/sec vs offiziellem Image
# ─────────────────────────────────────────────────────────────────────────────

ARG CUDA_IMAGE=nvcr.io/nvidia/pytorch:25.02-py3
FROM ${CUDA_IMAGE}

# ── Build-Argumente ────────────────────────────────────────────────────────────
ARG TORCH_CUDA_ARCH_LIST="12.0+PTX"
ARG MAX_JOBS=8
ARG NVCC_THREADS=2
ARG VLLM_REF=main

# ── System-Abhängigkeiten ──────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
        git curl wget \
        libsndfile1 ffmpeg \
        && rm -rf /var/lib/apt/lists/*

# ── vLLM aus Quellcode bauen (Blackwell-optimiert) ────────────────────────────
WORKDIR /build
RUN git clone --depth=1 --branch "${VLLM_REF}" \
        https://github.com/vllm-project/vllm.git .

# Build-System-Abhängigkeiten
RUN pip install --no-cache-dir \
        setuptools wheel ninja cmake packaging \
        'setuptools-scm>=8'

ENV TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH_LIST}
ENV MAX_JOBS=${MAX_JOBS}
ENV NVCC_THREADS=${NVCC_THREADS}

# use_existing_torch.py verhindert doppelten PyTorch-Download
RUN python use_existing_torch.py . 2>/dev/null || true

RUN pip install --no-cache-dir --no-build-isolation . \
    && rm -rf /build /root/.cache/pip

# ── Runtime-Optimierungen ──────────────────────────────────────────────────────
# NCCL DMA-BUF: schnellerer GPU↔GPU Transfer (Kernel 6.14+)
ENV NCCL_DMABUF_ENABLE=1

# Flash Attention 3 noch inkompatibel mit Blackwell GB206 — explizit v2
ENV VLLM_FLASH_ATTN_VERSION=2

# PyTorch Inductor Cache für JIT-kompilierte Kernel
ENV TORCHINDUCTOR_CACHE_DIR=/root/.cache/torchinductor

# Multi-Process Spawn (stabiler in Containern als fork)
ENV VLLM_WORKER_MULTIPROC_METHOD=spawn

# ── Healthcheck ────────────────────────────────────────────────────────────────
HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
    CMD curl -sf http://localhost:8000/health || exit 1

WORKDIR /workspace

ENTRYPOINT ["python", "-m", "vllm.entrypoints.openai.api_server"]
# Standard-CMD für Qwen2.5-Omni/Qwen3.5-Omni (~5-6 GB VRAM, 10 GB Reserve)
CMD ["--model", "Qwen/Qwen2.5-Omni-7B", \
     "--trust-remote-code", \
     "--gpu-memory-utilization", "0.85", \
     "--max-model-len", "8192", \
     "--limit-mm-per-prompt", "audio=5", \
     "--enable-reasoning", \
     "--reasoning-parser", "deepseek_r1", \
     "--served-model-name", "omni"]
